// stage content:
(lib._2024_conversationsRTB2platforms_html5_diy_x_value_en_us_300x250 = function(mode,startPosition,loop,reversed) {
if (loop == null) { loop = true; }
if (reversed == null) { reversed = false; }
	var props = new Object();
	props.mode = mode;
	props.startPosition = startPosition;
	props.labels = {};
	props.loop = loop;
	props.reversed = reversed;
	cjs.MovieClip.apply(this,[props]);

	this.actionFrames = [0,130];
	// timeline functions:
	this.frame_0 = function() {
		// MAIN ANIMATION
		var clicktag = this.clicktag_btn;
		var cta = this.cta_btn;
		
		clicktag.addEventListener("click", f_ClickTag); //Main ClickTag
		//cta.addEventListener("click", f_ClickTag); //CTA ClickTag
		
		 //CTA Rollover animation
		//cta.addEventListener("mouseover", f_rollOver.bind(this));
		
		function f_ClickTag() {
			window.open( clickTag, "_blank");
		}
		
		
		// CTA rollover
		//function f_rollOver() {
		//    this.cta_btn.shine_mc.play();
		//}
	}
	this.frame_130 = function() {
		// code for loop animation
		if (!this.looped) this.looped = 1;
		if (this.looped++ == 3) this.stop();
	}

	// actions tween:
	this.timeline.addTween(cjs.Tween.get(this).call(this.frame_0).wait(130).call(this.frame_130).wait(19));

	// Main_Border
	this.shape = new cjs.Shape();
	this.shape.graphics.f().s("#000000").ss(1,0,0,3).p("A3WzcMAutAAAMAAAAm5MgutAAAg");
	this.shape.setTransform(150,125);

	this.timeline.addTween(cjs.Tween.get(this.shape).wait(149));

	// clickTag_btn
	this.clicktag_btn = new lib.btn_clickTag();
	this.clicktag_btn.name = "clicktag_btn";
	this.clicktag_btn.setTransform(80,300.6,1,1,0,0,0,80,300.6);
	new cjs.ButtonHelper(this.clicktag_btn, 0, 1, 2, false, new lib.btn_clickTag(), 3);

	this.timeline.addTween(cjs.Tween.get(this.clicktag_btn).wait(149));

	// Black_Logo
	this.instance = new lib.f2_logo_300x250();
	this.instance.setTransform(0,0,0.5,0.5);

	this.instance_1 = new lib.Tween29("synched",0);
	this.instance_1.setTransform(150,125);
	this.instance_1._off = true;

	this.instance_2 = new lib.Tween30("synched",0);
	this.instance_2.setTransform(150,125);
	this.instance_2.alpha = 0;

	this.timeline.addTween(cjs.Tween.get({}).to({state:[]}).to({state:[{t:this.instance}]},89).to({state:[{t:this.instance_1}]},52).to({state:[{t:this.instance_2}]},7).wait(1));
	this.timeline.addTween(cjs.Tween.get(this.instance_1).wait(141).to({_off:false},0).to({_off:true,alpha:0},7).wait(1));

